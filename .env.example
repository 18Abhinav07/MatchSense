# Required for every server boot.
DATABASE_URL=

# Live product source. Set to txline_hackathon; use synthetic_demo only for tests.
DATA_RIGHTS_MODE=
TXLINE_API_TOKEN=

# Railway supplies PORT; the server also has safe HOST/PORT defaults when unset.
HOST=
PORT=

# Optional commentary enhancement. Deterministic fallbacks remain available.
GROQ_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Optional at boot, but all three are required together for Web Push.
VAPID_SUBJECT=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
