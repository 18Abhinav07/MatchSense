{
  "name": "@matchsense/server",
  "version": "0.0.0",
  "private": true,
  "description": "MatchSense production server shell.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/static": "10.1.0",
    "@matchsense/commentary": "workspace:*",
    "@matchsense/contracts": "workspace:*",
    "@matchsense/db": "workspace:*",
    "@matchsense/event-engine": "workspace:*",
    "@matchsense/replay": "workspace:*",
    "@matchsense/txline-adapter": "workspace:*",
    "fastify": "5.10.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "tsx": "4.23.1"
  }
}
