{
  "name": "@matchsense/db",
  "version": "0.0.0",
  "private": true,
  "description": "MatchSense PostgreSQL persistence boundary.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:check": "node dist/cli.js check",
    "db:migrate": "node dist/cli.js migrate",
    "test": "vitest run --root ../.. packages/db/src",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "postgres": "3.4.9"
  }
}
