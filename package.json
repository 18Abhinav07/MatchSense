{
  "name": "matchsense-production",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "node --test scripts/*.test.mjs && vitest run",
    "typecheck": "corepack pnpm --recursive --if-present run typecheck",
    "build": "corepack pnpm --recursive --if-present run build",
    "format:check": "prettier --check .",
    "install:frozen": "corepack pnpm install --frozen-lockfile"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
