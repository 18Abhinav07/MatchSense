FROM node:24.18.0-bookworm-slim@sha256:6f7b03f7c2c8e2e784dcf9295400527b9b1270fd37b7e9a7285cf83b6951452d AS generator

RUN apt-get update \
  && apt-get install -y --no-install-recommends ffmpeg \
  && rm -rf /var/lib/apt/lists/*

COPY apps/server/scripts/generate-demo-audio.sh /usr/local/bin/generate-demo-audio
RUN chmod 0755 /usr/local/bin/generate-demo-audio \
  && generate-demo-audio /out

FROM scratch AS export
COPY --from=generator /out/silence.mp3 /silence.mp3
COPY --from=generator /out/goal-cue.mp3 /goal-cue.mp3
